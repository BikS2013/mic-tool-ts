{
  "name": "mic-tool-ts",
  "version": "0.1.0",
  "description": "CLI tool that streams microphone audio to Soniox or ElevenLabs real-time STT and prints transcripts to stdout",
  "type": "module",
  "bin": {
    "mic-tool-ts": "./dist/index.js"
  },
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "tsc -p . && mkdir -p dist/ui/renderer && cp src/ui/renderer/index.html src/ui/renderer/styles.css dist/ui/renderer/",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "pnpm audit --audit-level=high"
  },
  "dependencies": {
    "@soniox/node": "^2.0.3",
    "commander": "^14.0.3",
    "electron": "^42.1.0",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
